<section class="section">
  <div class="container narrow">
    <div class="card form-card">
      <h1>Inscription</h1>
      <%- include('../partials/form-errors', { errors }) %>
      <form method="post" action="/register" class="stack">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="text" name="firstName" placeholder="Prenom" value="<%= oldInput.firstName || '' %>" required />
        <input type="text" name="lastName" placeholder="Nom" value="<%= oldInput.lastName || '' %>" required />
        <input type="email" name="email" placeholder="Email" value="<%= oldInput.email || '' %>" required />
        <input type="password" name="password" placeholder="Mot de passe" required />
        <button class="btn btn-primary" type="submit">Creer mon compte</button>
      </form>
    </div>
  </div>
</section>
