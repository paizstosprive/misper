<section class="section">
  <div class="container narrow">
    <div class="quiz-card">
      <div class="quiz-top">
        <span class="pill pill-progress">Question <%= progress %> / <%= attempt.totalQuestions %></span>
        <span class="quiz-meta"><%= quizAnswer.question.chapterCode %> - <%= quizAnswer.question.chapterTitle %></span>
      </div>
      <h1 class="quiz-title"><%= quizAnswer.question.questionText %></h1>
      <img class="quiz-image" src="<%= quizAnswer.question.imagePath %>" alt="Illustration de question" />
      <form action="/quiz/<%= attempt.id %>" method="post" class="choice-list">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="questionOrder" value="<%= quizAnswer.questionOrder %>" />
        <label class="choice-card">
          <input type="radio" name="selectedChoice" value="A" required />
          <span class="choice-letter">A</span>
          <span class="choice-text"><%= quizAnswer.question.choiceA %></span>
        </label>
        <label class="choice-card">
          <input type="radio" name="selectedChoice" value="B" required />
          <span class="choice-letter">B</span>
          <span class="choice-text"><%= quizAnswer.question.choiceB %></span>
        </label>
        <label class="choice-card">
          <input type="radio" name="selectedChoice" value="C" required />
          <span class="choice-letter">C</span>
          <span class="choice-text"><%= quizAnswer.question.choiceC %></span>
        </label>
        <div class="quiz-actions">
          <button class="btn btn-primary" type="submit">Valider ma reponse</button>
        </div>
      </form>
    </div>
  </div>
</section>
