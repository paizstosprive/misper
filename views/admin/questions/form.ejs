<section class="section">
  <div class="container narrow">
    <div class="card form-card">
      <h1><%= question ? 'Modifier' : 'Nouvelle' %> question</h1>
      <form class="stack" action="<%= formAction %>" method="<%= method %>">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <select name="chapterCode" required>
          <% chapters.forEach((chapter) => { %>
            <option value="<%= chapter.code %>" <%= question?.chapterCode === chapter.code ? 'selected' : '' %>><%= chapter.code %> - <%= chapter.title %></option>
          <% }) %>
        </select>
        <input type="text" name="chapterTitle" placeholder="Titre chapitre" value="<%= question?.chapterTitle || '' %>" required />
        <textarea name="questionText" placeholder="Question" required><%= question?.questionText || '' %></textarea>
        <input type="text" name="choiceA" placeholder="Choix A" value="<%= question?.choiceA || '' %>" required />
        <input type="text" name="choiceB" placeholder="Choix B" value="<%= question?.choiceB || '' %>" required />
        <input type="text" name="choiceC" placeholder="Choix C" value="<%= question?.choiceC || '' %>" required />
        <select name="correctChoice" required>
          <% ['A', 'B', 'C'].forEach((value) => { %>
            <option value="<%= value %>" <%= question?.correctChoice === value ? 'selected' : '' %>><%= value %></option>
          <% }) %>
        </select>
        <textarea name="explanation" placeholder="Explication" required><%= question?.explanation || '' %></textarea>
        <input type="text" name="imagePath" placeholder="/images/img1.png" value="<%= question?.imagePath || '' %>" required />
        <select name="difficulty" required>
          <% ['beginner', 'intermediate'].forEach((value) => { %>
            <option value="<%= value %>" <%= question?.difficulty === value ? 'selected' : '' %>><%= value %></option>
          <% }) %>
        </select>
        <button class="btn btn-primary" type="submit">Enregistrer</button>
      </form>
    </div>
  </div>
</section>
