{
  "name": "permis-theorique-belgique",
  "version": "1.0.0",
  "description": "Plateforme d'entrainement au permis theorique B belge avec abonnement Stripe",
  "main": "app.js",
  "scripts": {
    "dev": "nodemon app.js",
    "start": "node app.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo:all",
    "db:seed": "sequelize-cli db:seed:all",
    "db:seed:undo": "sequelize-cli db:seed:undo:all",
    "prompts:generate": "node scripts/generateImagePrompts.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "connect-flash": "^0.1.1",
    "connect-session-sequelize": "^7.1.7",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.18.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "http-errors": "^2.0.0",
    "method-override": "^3.0.0",
    "nodemailer": "^9.0.0",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5",
    "sequelize-cli": "^6.6.2",
    "sqlite3": "^5.1.7",
    "stripe": "^17.7.0",
    "stripe-cli": "^0.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
